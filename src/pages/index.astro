---
import '../styles/global.css';

const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const asset = (path) => `${baseUrl}${path.replace(/^\/+/, '')}`;

const siteUrl = 'https://SkyZeirry.github.io/Resume/';

const featuredWorks = [
  {
    title: '竹林阮乐快闪',
    category: 'Motion / Visual Design',
    image: asset('images/竹林阮乐快闪2.png'),
    description: '结合传统器乐意象与快闪视觉节奏，展示场景搭建、画面调度和成片包装能力。',
    tools: 'Blender / After Effects / Photoshop',
  },
  {
    title: '场景设计',
    category: 'Environment Design',
    image: asset('images/场景设计.png'),
    description: '用于展示空间设计、场景构图、材质搭配和整体氛围控制。',
    tools: 'Blender / Photoshop',
  },
  {
    title: '日落色渲染练习',
    category: 'Lighting / Rendering',
    image: asset('images/调了八百遍终于调出来的日落色4.png'),
    description: '重点呈现色彩调校、光影层次和最终画面情绪。',
    tools: 'Blender / Color Grading',
  },
];

const galleryImages = [
  'images/Untitled.png',
  'images/e7dec547e5a02c3ca60bdbcfb0653fe9.png',
  'images/cf16f480f8770ef778718088086963d9.jpg',
  'images/cdee135e7d584dd17c2359c6de4e9745.png',
  'images/bd53d763ad26cef4f89a128bc8e79267.png',
  'images/ac62760a4caee35801273985d16959c6.png',
  'images/3686325fbfcf5ea9534fb0eac58376b5.png',
  'images/0fb5c97d011109fb39d26551ee228a95.png',
];

const videos = [
  {
    title: '皮影主题视频',
    file: asset('videos/piying.mp4'),
    poster: asset('images/竹林阮乐快闪2.png'),
  },
  {
    title: 'KRT 作品视频',
    file: asset('videos/KRT(1).mp4'),
    poster: asset('images/场景设计.png'),
  },
  {
    title: '6月21日作品视频',
    file: asset('videos/6月21日 (1)(1).mp4'),
    poster: asset('images/调了八百遍终于调出来的日落色4.png'),
  },
];

const certificates = [
  {
    title: '大学英语六级成绩单',
    issuer: 'CET6',
    file: asset('certificates/CET6_202512_110590252202029_1.pdf'),
    type: 'PDF',
  },
  {
    title: '翻译证书',
    issuer: '能力证明',
    file: asset('certificates/translate_C0014_245020102.pdf'),
    type: 'PDF',
  },
  {
    title: '三等奖证书',
    issuer: '荣誉奖项',
    file: asset('certificates/三等奖.png'),
    image: asset('certificates/三等奖.png'),
    type: 'IMAGE',
  },
  {
    title: '北京印刷学院证书',
    issuer: '北京印刷学院',
    file: asset('certificates/北京印刷学院-2026054074.pdf'),
    type: 'PDF',
  },
  {
    title: '北京印刷学院证书',
    issuer: '北京印刷学院',
    file: asset('certificates/北京印刷学院-2026058540(1).pdf'),
    type: 'PDF',
  },
];

const workflow = [
  '前期调研与视觉定位',
  '模型、场景与镜头搭建',
  '材质灯光与渲染输出',
  '后期包装与作品整理',
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="高紫凌个人作品展示网站，包含视频作品、图片作品、证书展示、作者介绍与项目说明。"
    />
    <link rel="icon" type="image/png" href={asset('favicon.png')} />
    <title>高紫凌 | 个人作品展示站</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="#top">高紫凌</a>
      <nav aria-label="主导航">
        <a href="#works">作品</a>
        <a href="#gallery">图片</a>
        <a href="#showreel">视频</a>
        <a href="#certificates">证书</a>
        <a href="#about">关于</a>
      </nav>
    </header>

    <main id="top">
      <section class="hero section-band">
        <div class="hero-copy">
          <p class="eyebrow">Portfolio Website</p>
          <h1>高紫凌个人作品展示</h1>
          <p class="hero-text">
            用于集中展示视觉设计、建模渲染、视频作品、证书材料和个人介绍。页面已经接入真实素材目录，可直接通过 GitHub Pages 分享给他人访问。
          </p>
          <div class="hero-actions">
            <a class="button primary" href="#works">查看作品</a>
            <a class="button secondary" href="#showreel">播放视频</a>
          </div>
        </div>
        <div class="hero-media" aria-label="首页代表作品图">
          <img src={asset('images/调了八百遍终于调出来的日落色4.png')} alt="代表作品预览" />
        </div>
      </section>

      <section class="intro-strip" aria-label="能力概览">
        <div>
          <strong>视觉设计</strong>
          <span>构图、色彩、版式与作品包装</span>
        </div>
        <div>
          <strong>视频展示</strong>
          <span>短片、快闪、过程演示与成片播放</span>
        </div>
        <div>
          <strong>材料证明</strong>
          <span>证书、奖项、成绩单与相关 PDF</span>
        </div>
      </section>

      <section class="section" id="works">
        <div class="section-heading">
          <p class="eyebrow">Selected Works</p>
          <h2>作品展示</h2>
          <p>精选部分代表作品作为首页项目卡片，点击后续可以扩展为独立详情页。</p>
        </div>
        <div class="work-grid">
          {featuredWorks.map((work) => (
            <article class="work-card">
              <img src={work.image} alt={`${work.title}预览图`} />
              <div class="work-card-body">
                <span>{work.category}</span>
                <h3>{work.title}</h3>
                <p>{work.description}</p>
                <small>{work.tools}</small>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="section gallery-section" id="gallery">
        <div class="section-heading">
          <p class="eyebrow">Image Gallery</p>
          <h2>图片作品</h2>
          <p>这里展示 public/images 目录中的真实图片素材。</p>
        </div>
        <div class="gallery-grid">
          {galleryImages.map((image, index) => (
            <img src={asset(image)} alt={`图片作品 ${index + 1}`} loading="lazy" />
          ))}
        </div>
      </section>

      <section class="section video-section" id="showreel">
        <div class="section-heading">
          <p class="eyebrow">Showreel</p>
          <h2>视频播放</h2>
          <p>视频文件来自 public/videos 目录，使用浏览器原生播放器播放。</p>
        </div>
        <div class="video-grid">
          {videos.map((video) => (
            <article class="video-card">
              <video controls preload="metadata" poster={video.poster}>
                <source src={video.file} type="video/mp4" />
                当前浏览器不支持视频播放。
              </video>
              <h3>{video.title}</h3>
            </article>
          ))}
        </div>
      </section>

      <section class="section process-section">
        <div class="section-heading">
          <p class="eyebrow">Workflow</p>
          <h2>作品介绍与制作流程</h2>
          <p>通过简短的流程说明，让访问者快速理解作品从概念到成片的制作方式。</p>
        </div>
        <div class="process-grid">
          {workflow.map((step, index) => (
            <article class="process-card">
              <span>0{index + 1}</span>
              <h3>{step}</h3>
              <p>可补充该阶段使用的软件、技术难点、解决方案和最终输出成果。</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section" id="certificates">
        <div class="section-heading">
          <p class="eyebrow">Certificates</p>
          <h2>证书展示</h2>
          <p>证书和 PDF 文件来自 public/certificates 目录，点击卡片可打开原文件。</p>
        </div>
        <div class="certificate-grid">
          {certificates.map((certificate) => (
            <a class="certificate-card" href={certificate.file} target="_blank" rel="noreferrer">
              {certificate.image ? (
                <img class="certificate-preview" src={certificate.image} alt={`${certificate.title}预览`} />
              ) : (
                <span class="certificate-badge">{certificate.type}</span>
              )}
              <span>{certificate.title}</span>
              <strong>{certificate.issuer}</strong>
              <small>点击查看文件</small>
            </a>
          ))}
        </div>
      </section>

      <section class="section about" id="about">
        <div class="portrait">
          <img src={asset('images/cf16f480f8770ef778718088086963d9.jpg')} alt="作者头像或个人照片" />
        </div>
        <div>
          <p class="eyebrow">About</p>
          <h2>作者介绍</h2>
          <p>
            这里可以填写学习背景、创作方向、软件能力、项目经历和当前目标。建议突出最能代表个人能力的内容，例如视觉设计、建模渲染、视频制作或作品包装。
          </p>
          <p>
            可补充常用工具：Blender、Photoshop、After Effects、Premiere、Substance Painter 等，并说明你在项目中的核心职责。
          </p>
          <p class="share-url">公开访问地址：<a href={siteUrl}>{siteUrl}</a></p>
        </div>
      </section>
    </main>
  </body>
</html>
