---
import '../styles/global.css';

const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const asset = (path) => `${baseUrl}${path.replace(/^\/+/, '')}`;

const featuredWorks = [
  {
    title: '竹林阮乐快闪',
    category: 'Motion / Visual Design',
    image: asset('images/竹林阮乐快闪2.png'),
    description: '围绕传统音乐与东方意象进行视觉设计，呈现节奏、场景和画面包装能力。',
    tools: 'After Effects / Photoshop / Blender',
  },
  {
    title: '场景设计',
    category: 'Environment Design',
    image: asset('images/场景设计.png'),
    description: '展示空间构成、场景氛围、画面层次和视觉叙事能力。',
    tools: 'Blender / Photoshop',
  },
  {
    title: '日落色渲染练习',
    category: 'Lighting / Rendering',
    image: asset('images/调了八百遍终于调出来的日落色4.png'),
    description: '重点呈现光影控制、色彩调校和最终画面的情绪表达。',
    tools: 'Blender / Color Grading',
  },
];

const galleryImages = [
  'images/Untitled.png',
  'images/e7dec547e5a02c3ca60bdbcfb0653fe9.png',
  'images/cf16f480f8770ef778718088086963d9.jpg',
  'images/cdee135e7d584dd17c2359c6de4e9745.png',
  'images/bd53d763ad26cef4f89a128bc8e79267.png',
  'images/ac62760a4caee35801273985d16959c6.png',
  'images/3686325fbfcf5ea9534fb0eac58376b5.png',
  'images/0fb5c97d011109fb39d26551ee228a95.png',
];

const videos = [
  {
    title: '皮影主题视频',
    file: asset('videos/piying.mp4'),
    poster: asset('videos/皮影视频封面.png'),
  },
  {
    title: '廓如闻古音',
    file: asset('videos/廓如闻古音.mp4'),
    poster: asset('videos/廓如闻古音封面.png'),
  },
  {
    title: '木语廊桥',
    file: asset('videos/木语廊桥.mp4'),
    poster: asset('videos/木语廊桥封面.png'),
  },
  {
    title: '幻想光碟',
    file: asset('videos/幻想光碟.mp4'),
    poster: asset('videos/幻想光碟封面.png'),
  },
  {
    title: '离骚',
    file: asset('videos/离骚.mp4'),
    poster: asset('videos/离骚封面.png'),
  },
];

const certificates = [
  {
    title: '大学英语六级成绩单',
    issuer: 'CET6',
    file: asset('certificates/CET6_202512_110590252202029_1.pdf'),
    preview: asset('certificates/previews/CET6_202512_110590252202029_1.png'),
    previewType: 'image',
  },
  {
    title: '翻译证书',
    issuer: '能力证明',
    file: asset('certificates/translate_C0014_245020102.pdf'),
    preview: asset('certificates/previews/translate_C0014_245020102.png'),
    previewType: 'image',
  },
  {
    title: '三等奖证书',
    issuer: '荣誉奖项',
    file: asset('certificates/三等奖.png'),
    preview: asset('certificates/三等奖.png'),
    previewType: 'image',
  },
  {
    title: '北京印刷学院证书',
    issuer: '北京印刷学院',
    file: asset('certificates/北京印刷学院-2026054074.pdf'),
    preview: asset('certificates/previews/北京印刷学院-2026054074.png'),
    previewType: 'image',
  },
  {
    title: '北京印刷学院证书',
    issuer: '北京印刷学院',
    file: asset('certificates/北京印刷学院-2026058540(1).pdf'),
    preview: asset('certificates/previews/北京印刷学院-2026058540(1).png'),
    previewType: 'image',
  },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="高紫凌个人作品展示网站，包含视频作品、图片作品、证书展示、作者介绍与项目说明。"
    />
    <link rel="icon" type="image/png" sizes="64x64" href={asset('favicon.png?v=4')} />
    <link rel="shortcut icon" type="image/png" href={asset('favicon.png?v=4')} />
    <title>高紫凌 | 个人作品展示站</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="#top">高紫凌</a>
      <nav aria-label="主导航">
        <a href="#works">作品</a>
        <a href="#gallery">图片</a>
        <a href="#showreel">视频</a>
        <a href="#certificates">证书</a>
        <a href="#about">关于</a>
      </nav>
    </header>

    <main id="top">
      <section class="hero section-band">
        <div class="hero-copy">
          <p class="eyebrow">Portfolio</p>
          <h1>高紫凌个人作品展示</h1>
          <p class="hero-text">
            我关注视觉设计、视频表达与数字内容创作，擅长把传统文化元素、空间氛围和动态节奏转化为完整的视觉作品。这里集中展示我的视频项目、图片作品、证书材料和阶段性创作成果。
          </p>
          <div class="hero-actions">
            <a class="button primary" href="#works">查看作品</a>
            <a class="button secondary" href="#showreel">播放视频</a>
          </div>
        </div>
        <div class="hero-media" aria-label="首页代表作品图">
          <img src={asset('images/调了八百遍终于调出来的日落色4.png')} alt="代表作品预览" />
        </div>
      </section>

      <section class="intro-strip" aria-label="能力概览">
        <div>
          <strong>视觉设计</strong>
          <span>构图、色彩、版式与作品包装</span>
        </div>
        <div>
          <strong>视频创作</strong>
          <span>短片、快闪、镜头节奏与成片表达</span>
        </div>
        <div>
          <strong>数字内容</strong>
          <span>场景、渲染、动态视觉与展示整理</span>
        </div>
      </section>

      <section class="section" id="works">
        <div class="section-heading">
          <p class="eyebrow">Selected Works</p>
          <h2>作品展示</h2>
          <p>精选部分代表作品，展示我的视觉方向、画面处理和项目完成能力。</p>
        </div>
        <div class="work-grid">
          {featuredWorks.map((work) => (
            <article class="work-card">
              <img src={work.image} alt={`${work.title}预览图`} />
              <div class="work-card-body">
                <span>{work.category}</span>
                <h3>{work.title}</h3>
                <p>{work.description}</p>
                <small>{work.tools}</small>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="section gallery-section" id="gallery">
        <div class="section-heading">
          <p class="eyebrow">Image Gallery</p>
          <h2>图片作品</h2>
          <p>图片区域用于展示视觉成图、场景设计、过程图和作品细节。</p>
        </div>
        <div class="gallery-grid">
          {galleryImages.map((image, index) => (
            <img src={asset(image)} alt={`图片作品 ${index + 1}`} loading="lazy" />
          ))}
        </div>
      </section>

      <section class="section video-section" id="showreel">
        <div class="section-heading">
          <p class="eyebrow">Showreel</p>
          <h2>视频播放</h2>
          <p>视频封面使用视频目录中对应的截图文件，点击即可播放完整视频。</p>
        </div>
        <div class="video-grid">
          {videos.map((video) => (
            <article class="video-card">
              <video controls preload="metadata" poster={video.poster}>
                <source src={video.file} type="video/mp4" />
                当前浏览器不支持视频播放。
              </video>
              <h3>{video.title}</h3>
            </article>
          ))}
        </div>
      </section>

      <section class="section" id="certificates">
        <div class="section-heading">
          <p class="eyebrow">Certificates</p>
          <h2>证书展示</h2>
          <p>证书区域展示我的语言能力、学习经历和相关荣誉，点击可打开原始文件。</p>
        </div>
        <div class="certificate-grid">
          {certificates.map((certificate) => (
            <article class="certificate-card">
              <div class="certificate-preview-wrap">
                <img class="certificate-preview" src={certificate.preview} alt={`${certificate.title}预览`} />
              </div>
              <span>{certificate.title}</span>
              <strong>{certificate.issuer}</strong>
              <a class="certificate-link" href={certificate.file} target="_blank" rel="noreferrer">
                打开原文件
              </a>
            </article>
          ))}
        </div>
      </section>

      <section class="section about" id="about">
        <div class="portrait">
          <img src={asset('images/cf16f480f8770ef778718088086963d9.jpg')} alt="作者头像或个人照片" />
        </div>
        <div>
          <p class="eyebrow">About</p>
          <h2>作者介绍</h2>
          <p>
            我是高紫凌，作品方向集中在视觉设计、视频创作和数字内容表达。我的项目通常从主题概念出发，结合图像、影像、色彩和节奏，完成面向展示、传播或作品集呈现的视觉内容。
          </p>
          <p>
            我希望通过这些作品展示自己的审美判断、执行能力和持续创作能力，也希望让访问者能直接看到我的视频、图片作品和相关证明材料。
          </p>
        </div>
      </section>
    </main>
  </body>
</html>
